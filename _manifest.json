{
  "manifest_version": 2,
  "version": "0.3.0",
  "name": "Codex CLI QQ 调度器",
  "description": "通过 QQ 命令在 MaiBot 所在服务器上运行 Codex CLI，并可通过 NapCat HTTP API 将产物文件直传回当前聊天流；也保留远程 HTTP Agent 模式。",
  "author": {
    "name": "Arcczr",
    "url": "https://github.com/Arcczr"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Arcczr/maibot-codex-plugin",
    "homepage": "https://github.com/Arcczr/maibot-codex-plugin",
    "documentation": "https://github.com/Arcczr/maibot-codex-plugin#readme",
    "issues": "https://github.com/Arcczr/maibot-codex-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.2",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "httpx",
      "version_spec": ">=0.28.0"
    }
  ],
  "plugin_type": "integration",
  "display": {
    "icon": {
      "type": "lucide",
      "value": "terminal",
      "fallback": "bot"
    }
  },
  "capabilities": [
    "send.text",
    "send.custom",
    "message.get_by_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": [
      "zh-CN"
  ]
},
  "id": "arcczr.remote-codex-agent"
}
